{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis Guarded HUD",
  "version": "0.1.0",
  "identifier": "com.jarvis.guardedhud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Jarvis Guarded HUD",
        "width": 1600,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}

