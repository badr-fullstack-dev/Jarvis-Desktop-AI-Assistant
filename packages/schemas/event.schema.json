{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jarvis/event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "payload",
    "signature",
    "previous_signature"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "signature": {
      "type": "string"
    },
    "previous_signature": {
      "type": "string"
    }
  }
}

