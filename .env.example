# Jarvis Guarded Desktop Assistant — example environment.
#
# Copy this file to `.env` (which is git-ignored) and fill in only what
# you need. The assistant is designed to run with NONE of these set; the
# values below are documented opt-ins, not requirements.
#
# Never commit a real `.env`. Never paste a populated copy into issues
# or PRs.

# --- Audit log signing ---------------------------------------------------
# HMAC secret used to chain-sign runtime/events.jsonl.
# If unset, services/orchestrator/src/jarvis_core/api.py generates a
# random per-install key at runtime/audit.key. Override here only if you
# want to share the same key across machines (NOT recommended).
# JARVIS_AUDIT_SECRET=

# --- Local OCR (off by default) -----------------------------------------
# Provider for screen OCR. Default = a clearly-labelled "no OCR" stub.
# JARVIS_OCR_PROVIDER=windows-media-ocr
# JARVIS_OCR_LANGUAGE=en-US

# --- Local speech-to-text (off by default) ------------------------------
# Default = a clearly-labelled stub provider; nothing real happens
# without explicit opt-in. See voice_providers.py.
# JARVIS_STT_PROVIDER=stub
# JARVIS_STT_MODEL=base.en
# JARVIS_STT_MODEL_DIR=
# JARVIS_STT_COMPUTE=int8
# JARVIS_STT_DEVICE=cpu
# JARVIS_STT_LANGUAGE=en
# JARVIS_FFMPEG=ffmpeg
# JARVIS_WHISPERCPP_BIN=
# JARVIS_STT_DEBUG_DIR=
